/* 角色 */
.character {
    background-color: rgba(26,21,18,0.72);
    align-items: center; justify-content: center;
}
.character__panel { width: 640px; }
.character__body { flex-direction: row; padding: 10px 0; }
.character__portrait {
    width: 160px; height: 220px;
    background-color: #DCCCAE;
    border-top-width: 2px; border-bottom-width: 2px;
    border-left-width: 2px; border-right-width: 2px;
    border-top-color: #C9A24C; border-bottom-color: #C9A24C;
    border-left-color: #C9A24C; border-right-color: #C9A24C;
    border-top-left-radius: 4px;    border-top-right-radius: 4px;
    border-bottom-left-radius: 4px; border-bottom-right-radius: 4px;
    margin-right: 18px;
}
.character__stats { flex-grow: 1; }
.stat-row {
    padding: 8px 4px;
    color: #1A1512;
    border-bottom-width: 1px; border-bottom-color: #C9A24C; /* 细金线 */
    margin-bottom: 4px;
}
